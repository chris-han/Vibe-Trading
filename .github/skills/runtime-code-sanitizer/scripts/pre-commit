#!/usr/bin/env bash
# pre-commit hook: enforce sanitizer + prompt-guard coverage for runtime-generated code
set -euo pipefail

REPO_ROOT="$(git rev-parse --show-toplevel)"
CHECKER="$REPO_ROOT/.github/skills/runtime-code-sanitizer/scripts/check_sanitizers.py"

# Only run when service.py or the checker itself is in the staged changeset
# (avoid slowing down every commit that only touches frontend/docs).
RELEVANT=$(git diff --cached --name-only | grep -E \
  'agent/src/session/service\.py|check_sanitizers\.py' || true)

if [ -z "$RELEVANT" ]; then
  exit 0
fi

echo "🔍 runtime-code-sanitizer: checking staged changes..."

# Prefer the project venv; fall back to system python3
PYTHON="${REPO_ROOT}/agent/.venv/bin/python"
if [ ! -x "$PYTHON" ]; then
  PYTHON="$(command -v python3 || command -v python)"
fi

if ! "$PYTHON" "$CHECKER"; then
  echo ""
  echo "❌ Commit blocked: fix the sanitizer issues above, then re-commit."
  echo "   To skip this check (NOT recommended): git commit --no-verify"
  exit 1
fi
