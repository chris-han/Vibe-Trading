# ============================================================================
# LLM Provider
# ============================================================================
# Options: azure, openai, openrouter, deepseek, qwen
LANGCHAIN_PROVIDER=azure

# Azure OpenAI
AZURE_OPENAI_API_KEY=your-azure-key
AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com/
AZURE_OPENAI_DEPLOYMENT_NAME=gpt-4o
AZURE_OPENAI_API_VERSION=2025-01-01-preview

# OpenAI / OpenRouter (when LANGCHAIN_PROVIDER=openai or openrouter)
# OPENAI_API_KEY=your-key
# OPENAI_BASE_URL=https://api.openai.com/v1

# Hermes / Kimi Code (recommended for current runtime)
# Entrypoint: https://api.kimi.com/coding/v1
KIMI_API_KEY=your-kimi-key
KIMI_BASE_URL=https://api.kimi.com/coding/v1
HERMES_INFERENCE_PROVIDER=kimi-coding
HERMES_MODEL=kimi-for-coding
KIMI_USER_AGENT=RooCode/1.0.0
HERMES_REASONING_EFFORT=medium
HERMES_MAX_OUTPUT_TOKENS=32768
HERMES_CONTEXT_WINDOW=262144

LANGCHAIN_MODEL_NAME=gpt-4o
LANGCHAIN_TEMPERATURE=0.0

# ============================================================================
# Data Providers
# ============================================================================
# A-shares: Tushare Pro (requires token, https://tushare.pro)
TUSHARE_TOKEN=your-tushare-token
# HK/US equities: yfinance (free, no key needed)
# Crypto: OKX public API (free, no key needed)

# ============================================================================
# Runtime
# ============================================================================
TIMEOUT_SECONDS=2400
MAX_RETRIES=5

DASHSCOPE_API_KEY=sk-bdc5e5ca198f4f5f88cadf1653b74acc
DASHSCOPE_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1

# File-tool sandbox roots are derived from workspaces/<user_id>/agent.
# This path is determined by the runtime and is not configured via .env.
